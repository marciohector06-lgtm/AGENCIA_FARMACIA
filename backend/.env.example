ENVIRONMENT=development

# Connection string do backend via Connection Pooler do Supabase (modo
# Transaction, porta 6543), usando a role app_backend criada na FASE 1
# (database/migrations/0011_roles_grants.sql). Pegue host/porta em:
# Supabase Dashboard > Project Settings > Database > Connection Pooling.
#
# Note o formato de usuário do pooler: <role>.<project-ref>
#
# Antes de usar, defina a senha real da role (troque a placeholder):
#   ALTER ROLE app_backend WITH PASSWORD 'sua-senha-forte-aqui';
# e cole aqui a MESMA senha, com caracteres especiais url-encoded (@ -> %40).
# Nunca commite o .env real (já está no .gitignore).
DATABASE_URL=postgresql+asyncpg://app_backend.<PROJECT_REF>:REPLACE_WITH_REAL_SECRET@aws-<regiao>.pooler.supabase.com:6543/postgres

DB_ECHO=false
# Supabase exige TLS em conexão direta; só desative para um Postgres local.
DB_SSL_REQUIRE=true

CORS_ORIGINS=["http://localhost:3000"]

# Obrigatório — Settings falha ao instanciar sem isto (app/core/config.py).
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Nunca reaproveite a mesma chave de outro ambiente.
JWT_SECRET_KEY=

# FASE 0: qual ERPAdapter esta instalação usa. "mock" é o único implementado
# (app/integrations/mock_adapter.py) — ver app/integrations/registry.py.
ERP_PROVIDER=mock

# FASE 0/SEC-06: PATCH /produtos/{id}/tarja ainda não tem autenticação própria
# (depende da FASE 1). Mantenha false em qualquer ambiente exposto; só ligue
# em ambiente controlado (dev local, demo) sabendo que é público enquanto
# SEC-01 não existir.
TARJA_ENDPOINT_ENABLED=false

# Opcional: banco (ou schema) separado usado só pelos testes de integração em
# tests/test_produtos.py. Se vazio, esses testes são pulados automaticamente.
TEST_DATABASE_URL=

# Conexões síncronas por role de agente (FASE 3/4), usadas pelas Tools do
# CrewAI — nunca a app_backend. Use driver psycopg2 (sync), não asyncpg.
# Gere senhas fortes só pra essas roles de serviço, ex.:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
# e aplique com ALTER ROLE <role> WITH PASSWORD '...' para cada uma.
DATABASE_URL_AGENTE_ATENDENTE=postgresql+psycopg2://agente_atendente.<PROJECT_REF>:REPLACE_WITH_REAL_SECRET@aws-<regiao>.pooler.supabase.com:6543/postgres
DATABASE_URL_AGENTE_ESTOQUE=postgresql+psycopg2://agente_estoque.<PROJECT_REF>:REPLACE_WITH_REAL_SECRET@aws-<regiao>.pooler.supabase.com:6543/postgres
DATABASE_URL_AGENTE_FINANCEIRO=postgresql+psycopg2://agente_financeiro.<PROJECT_REF>:REPLACE_WITH_REAL_SECRET@aws-<regiao>.pooler.supabase.com:6543/postgres
DATABASE_URL_AGENTE_ORQUESTRADOR=postgresql+psycopg2://agente_orquestrador.<PROJECT_REF>:REPLACE_WITH_REAL_SECRET@aws-<regiao>.pooler.supabase.com:6543/postgres

# Provedor de LLM para os agentes: "gemini" ou "groq". Preencha só a chave do
# provedor escolhido.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GROQ_API_KEY=
